# Production Django Environment Variables
# Copy this file to .django and fill in your production values

DJANGO_SECRET_KEY="generate-a-strong-secret-key-here"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com

# AWS S3
USE_S3=True
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1

# Cache Settings
USE_CACHE=True
API_CACHE_TIMEOUT=3600
CACHE_HOST=redis://redis:6379/0
LAYER_HOST=redis

# Celery
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Site Configuration
SITE_URL=https://your-domain.com
BASE_URL=https://your-domain.com

# Email Configuration
DEFAULT_FROM_EMAIL=noreply@your-domain.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# Domain
DOMAIN=your-domain.com

# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Timeout
DEFAULT_TIMEOUT=60

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Django Admin
DJANGO_ADMIN_URL=admin-secret-path/

# Sentry (optional)
SENTRY_DSN=your-sentry-dsn
