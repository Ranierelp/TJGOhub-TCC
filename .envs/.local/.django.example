DJANGO_SECRET_KEY="your-secret-key-here-change-in-production"
DJANGO_DEBUG=True
BASE_URL=http://localhost:8000

# AWS S3 (desabilitado para local)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_REGION=us-east-1

# Cache Settings
USE_CACHE=True
API_CACHE_TIMEOUT=3600
CACHE_HOST=redis://redis:6379/0
LAYER_HOST=redis

# Celery
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Site Configuration
SITE_URL=http://localhost:8000

# Email Configuration (console backend para desenvolvimento)
DEFAULT_FROM_EMAIL=noreply@tjgohub.local
EMAIL_HOST_PASSWORD=
EMAIL_HOST=localhost
EMAIL_PORT=1025

# reCAPTCHA (opcional)
RECAPTCHA_SECRET_KEY=""

# Domain
DOMAIN=localhost:8000

# Database
DATABASE_URL=postgres://tjgohub_user:tjgohub_pass@postgres:5432/tjgohub_db

# Timeout
DEFAULT_TIMEOUT=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Django Admin
DJANGO_ADMIN_URL=admin/
